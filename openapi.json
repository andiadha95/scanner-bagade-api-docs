{
  "openapi": "3.0.0",
  "info": {
    "title": "Scanner Bagasi API",
    "description": "API Service untuk mengirim data scan bagasi X-Ray. Server akan otomatis memverifikasi barcode ke sistem TPS.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://192.168.1.245/scanner-bagade"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key untuk autentikasi. Hubungi admin untuk mendapatkan key."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/scan.php": {
      "post": {
        "summary": "Kirim scan bagasi",
        "description": "Mengirim data scan X-Ray bagasi. Server akan otomatis memverifikasi barcode ke sistem TPS.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["scanId", "barcodeScanId", "imageFront", "imageUp"],
                "properties": {
                  "scanId": {
                    "type": "string",
                    "description": "ID unik scan (harus unik)",
                    "example": "SCAN_CUSTOMER_001"
                  },
                  "scanDateTime": {
                    "type": "string",
                    "description": "Waktu scan (format: Y-m-d H:i:s)",
                    "example": "2026-05-16 10:30:00"
                  },
                  "barcodeScanId": {
                    "type": "string",
                    "description": "Nomor Barcode / HAWB",
                    "example": "B44896729000-001"
                  },
                  "entryGate": {
                    "type": "string",
                    "description": "Gate scanner",
                    "example": "GATE-A"
                  },
                  "entryLine": {
                    "type": "string",
                    "description": "Line scanner",
                    "example": "LINE-01"
                  },
                  "imageFront": {
                    "type": "string",
                    "description": "Gambar X-Ray tampak depan (format Base64)",
                    "example": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
                  },
                  "imageUp": {
                    "type": "string",
                    "description": "Gambar X-Ray tampak atas (format Base64)",
                    "example": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sukses - Scan berhasil disimpan"
          },
          "200": {
            "description": "Sukses - Data berhasil diupdate (scan ID sudah ada dengan barcode berbeda)"
          },
          "400": {
            "description": "Gagal - Field wajib tidak lengkap"
          },
          "401": {
            "description": "Gagal - API Key tidak valid"
          },
          "409": {
            "description": "Gagal - Scan ID dan barcode sudah ada"
          },
          "500": {
            "description": "Gagal - Internal server error"
          }
        }
      }
    }
  }
}
